# --- Database (required) ---
# SQLite file used by Prisma. Path is relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# --- Email digests (Resend) ---
# Get an API key at https://resend.com (free tier: ~3,000 emails/mo, 100/day).
# Leave blank to run without email — the "Send digest now" button will report
# that email is not configured instead of crashing.
RESEND_API_KEY=""
# The verified "from" address for digests (e.g. "Wedding Planner <planner@yourdomain.com>").
# With no verified domain you can use Resend's sandbox: "onboarding@resend.dev".
EMAIL_FROM="Wedding Planner <onboarding@resend.dev>"

# --- Weekly scheduled digest ---
# Shared secret that protects the cron route. Generate one, e.g. `openssl rand -hex 32`.
# The scheduler must send it as `Authorization: Bearer <CRON_SECRET>` or `?secret=<CRON_SECRET>`.
CRON_SECRET=""

# --- Optional live venue search (Google Places) ---
# Set to "true" to enable the venue search box. If false/unset, search is hidden
# and venues are manual-entry only. Venues are NEVER fabricated — results come
# only from the API, each with a source link.
VENUE_SEARCH_ENABLED="false"
# Google Places API (New) key. Billing must be enabled on the Google Cloud project.
# See README "Costs" — Places Text Search is billed per request after the free tier.
PLACES_API_KEY=""
