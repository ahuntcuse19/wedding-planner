# --- Backend — Google Sheets ---
# The app stores all data in one Google Sheet (a tab per entity). Set up a
# Google Cloud service account, enable the Google Sheets API, share your sheet
# with the service account's email (Editor), then run `npm run sheets:init`.
# Add these SAME three vars in Vercel: Settings → Environment Variables.
#
#   1. The spreadsheet id — the long token in the sheet URL:
#      https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_ID=""
#   2. The service account's email (…@…iam.gserviceaccount.com).
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
#   3. The service account's private key from its JSON key file. Keep the quotes
#      and the literal "\n" sequences exactly as they appear in the JSON; the app
#      converts them back to real newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# --- Access (shared password gate) ---
# Set BOTH to require a password before the app (and its API) can be used.
# Leave either blank to disable the gate (open app). APP_PASSWORD is the shared
# password; AUTH_SECRET signs the session cookie — generate one:
#   openssl rand -hex 32
APP_PASSWORD=""
AUTH_SECRET=""

# --- Email digests (Resend) ---
# Get an API key at https://resend.com (free tier: ~3,000 emails/mo, 100/day).
# Leave blank to run without email — the "Send digest now" button reports that
# email is not configured instead of crashing.
RESEND_API_KEY=""
# Verified "from" address (e.g. "Wedding Planner <planner@yourdomain.com>").
# With no verified domain use Resend's sandbox: "onboarding@resend.dev".
EMAIL_FROM="Wedding Planner <onboarding@resend.dev>"

# --- Weekly scheduled digest ---
# Shared secret protecting the cron route. Generate one: `openssl rand -hex 32`.
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""

# --- Optional live venue search (Google Places) ---
# "true" enables the venue search box. If false/unset, search is hidden and
# venues are manual-entry only. Results come only from the API, never fabricated.
VENUE_SEARCH_ENABLED="false"
# Google Places API (New) key. Billing must be enabled on the Google Cloud project.
PLACES_API_KEY=""
